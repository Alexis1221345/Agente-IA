# ─────────────────────────────────────────────────────────────
# LLM
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────
# Google Calendar
#
# HOW TO GET THESE:
#   1. Google Cloud Console → nuevo proyecto (o usa uno existente)
#   2. APIs & Services → Enable "Google Calendar API"
#   3. IAM & Admin → Service Accounts → Create service account
#   4. En la cuenta de servicio → Keys → Add Key → JSON
#      Descarga el .json — pégalo aquí en UNA sola línea como GOOGLE_SERVICE_ACCOUNT_KEY_JSON
#   5. Google Calendar → Settings → Share with specific people →
#      agrega el client_email del JSON con permiso "Make changes to events"
#   6. Copia el Calendar ID desde Settings → Integrate calendar
# ─────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}

GOOGLE_CALENDAR_ID=xxxxxxxx@group.calendar.google.com

# (Alternativa al JSON inline) Ruta al archivo .json de la cuenta de servicio:
# GOOGLE_CREDENTIALS_PATH=./config/credentials/mi-restaurante.json

# ─────────────────────────────────────────────────────────────
# Configuración del restaurante
# Cambia estos valores para adaptar el agente a cada restaurante.
# ─────────────────────────────────────────────────────────────
RESTAURANT_ID=demo
RESTAURANT_NAME=La Buena Mesa
RESTAURANT_TIMEZONE=America/Mexico_City

# ── Horario de servicio ──────────────────────────────────────
# El bot toma y confirma reservas 24/7, pero la hora de la
# reserva debe caer dentro de estos horarios de operación.
# Formato: HH:MM-HH:MM  |  "closed" = cerrado ese día
SCHEDULE_MONDAY=closed
SCHEDULE_TUESDAY=13:00-22:00
SCHEDULE_WEDNESDAY=13:00-22:00
SCHEDULE_THURSDAY=13:00-22:00
SCHEDULE_FRIDAY=13:00-23:00
SCHEDULE_SATURDAY=13:00-23:00
SCHEDULE_SUNDAY=13:00-21:00

RESTAURANT_SLOT_DURATION=90
RESTAURANT_CAPACITY_PER_SLOT=30
RESTAURANT_BOOKABLE_QUOTA=0.8
RESTAURANT_MAX_AUTO_GROUP=8
RESTAURANT_HUMAN_PHONE=+52 55 1234 5678
RESTAURANT_CANCELLATION_POLICY=Puedes cancelar sin costo hasta 2 horas antes de tu reserva.
RESTAURANT_FAQ={"estacionamiento":"Sí, contamos con valet parking de 14:00 a 22:00.","mascotas|perros|animales":"Lo sentimos, no permitimos mascotas.","niños|bebés|silla":"Con gusto te preparamos una silla para bebé."}

# ─────────────────────────────────────────────────────────────
# WhatsApp — Meta Cloud API
#
# HOW TO GET THESE:
#   1. developers.facebook.com → My Apps → Create App → Business
#   2. Add product: WhatsApp → Getting Started
#      - META_ACCESS_TOKEN    → Temporary/permanent access token
#      - META_PHONE_NUMBER_ID → ID del número de WhatsApp
#   3. WhatsApp → Configuration → Webhook:
#      - META_VERIFY_TOKEN    → cadena que tú inventas
#   4. App Settings → Basic → App Secret:
#      - META_APP_SECRET      → para validar firma del webhook
# ─────────────────────────────────────────────────────────────
META_VERIFY_TOKEN=mi_token_secreto_inventado
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=

# ─────────────────────────────────────────────────────────────
# Base de datos
# ─────────────────────────────────────────────────────────────
DATABASE_URL=./data/agent.db

# ─────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
# Simulación local (solo desarrollo)
# ─────────────────────────────────────────────────────────────
SIM_PHONE=+521XXXXXXXXXX
LLM_MOCK=false

# ─────────────────────────────────────────────────────────────
# Reseñas de Google (Google Business Profile)
# ─────────────────────────────────────────────────────────────
# Default global si el restaurante no define reviews_poll_minutes en el Sheet maestro
# (columna AB de la pestaña Restaurantes). 1440 = 1 vez al día.
REVIEWS_POLL_MINUTES=1440
