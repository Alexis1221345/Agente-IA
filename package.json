{
  "name": "restaurant-agent",
  "version": "0.1.0",
  "description": "WhatsApp reservation AI agent for restaurants (multi-tenant)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc",
    "simulate": "tsx src/channels/cli.ts",
